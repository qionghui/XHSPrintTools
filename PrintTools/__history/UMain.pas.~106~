procedure TForm1.ApplyFilter(const FilterText: string);
var
  i, j: Integer;
  Match: Boolean;
begin
  // 遍历每一行（从第一行开始，跳过标题行）
  for i := 1 to StringGrid1.RowCount - 1 do
  begin

    Match := False;

    // 遍历每一列，检查是否匹配筛选条件
    for j := 0 to StringGrid1.ColCount - 1 do
    begin
      if (FilterText = '') or (Pos(FilterText, StringGrid1.Cells[j, i]) > 0) then
      begin
        Match := True;
        Break;
      end;
    end;

    // 设置行高（0 表示隐藏，-1 表示默认高度）
    if Match then
      StringGrid1.RowHeights[i] := FRowHeights // 显示匹配的行
    else
      StringGrid1.RowHeights[i] := 0; // 隐藏不匹配的行
  end;
end;

procedure TForm1.LoadExcelToGrid(const FileName: string; StringGrid: TStringGrid);
var
  ExcelApp, Workbook, Sheet: Variant;
  RowCount, ColCount, i, j: Integer;
begin
  // 初始化Excel应用程序
  ExcelApp := CreateOleObject('Excel.Application');
  try
    ExcelApp.Visible := False;
    ExcelApp.DisplayAlerts := False;

    // 打开工作簿
    Workbook := ExcelApp.Workbooks.Open(FileName);
    try
      // 获取第一个工作表
      Sheet := Workbook.Sheets[1];

      // 获取行数和列数
      RowCount := Sheet.UsedRange.Rows.Count;
      ColCount := Sheet.UsedRange.Columns.Count;

      // 设置StringGrid的行数和列数
      StringGrid.RowCount := RowCount; // 不需要额外行，因为列名已经在Excel中
      StringGrid.ColCount := ColCount + 1; // +1 用于新增的“数量”列

      // 设置第一行的列名
      StringGrid.Cells[0, 0] := '数量'; // 新增的“数量”列
      for j := 1 to ColCount do
      begin
        StringGrid.Cells[j, 0] := Sheet.Cells[1, j].Text; // Excel中的列名
      end;

      // 加载Excel数据到StringGrid（从第二行开始）
      for i := 2 to RowCount do
      begin
        // 设置“数量”列的默认值
        StringGrid.Cells[0, i - 1] := '';

        // 加载Excel数据
        for j := 1 to ColCount do
        begin
          StringGrid.Cells[j, i - 1] := Sheet.Cells[i, j].Text;
        end;
      end;
    finally
      // 关闭工作簿
      Workbook.Close(False);
    end;
  finally
    // 退出Excel应用程序
    ExcelApp.Quit;
    ExcelApp := Unassigned;
  end;
  AutoSizeColumns(StringGrid);
end;


