  end;
end;

procedure TForm1.SaveGridToExcel(const FileName: string; StringGrid: TStringGrid);
var
  ExcelApp, Workbook, Sheet: Variant;
  i, j, ExcelRow: Integer;
begin
  // 初始化Excel应用程序
  ExcelApp := CreateOleObject('Excel.Application');
  try
    ExcelApp.Visible := False;
    ExcelApp.DisplayAlerts := False;

    // 创建新工作簿
    Workbook := ExcelApp.Workbooks.Add;
    try
      // 获取第一个工作表
      Sheet := Workbook.Sheets[1];

      // 写入列名（第一行）
      for j := 0 to StringGrid.ColCount - 1 do
      begin
        Sheet.Cells[1, j + 1] := StringGrid.Cells[j, 0];
      end;

      // 初始化Excel行号（从第二行开始）
      ExcelRow := 2;

      // 将StringGrid的内容写入Excel
      for i := 1 to StringGrid.RowCount - 1 do
      begin
        // 筛选“数量”列大于0的行
        if StrToIntDef(StringGrid.Cells[0, i], 0) > 0 then
        begin
          // 写入当前行数据
          for j := 0 to StringGrid.ColCount - 1 do
          begin
            Sheet.Cells[ExcelRow, j + 1] := StringGrid.Cells[j, i];
          end;
          // 增加Excel行号
          Inc(ExcelRow);
        end;
      end;

      // 保存工作簿
      if ExcelRow > 2 then
        Workbook.SaveAs(FileName);
    finally
      // 关闭工作簿
      Workbook.Close(False);
    end;
  finally
    // 退出Excel应用程序
    ExcelApp.Quit;
    ExcelApp := Unassigned;
  end;
end;

procedure TForm1.StringGrid1MouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
var
  Col, Row: Longint;
  CurrentValue: Integer;
  CellText: string;
begin
  // 获取点击的单元格位置
  StringGrid1.MouseToCell(X, Y, Col, Row);

  // 检查是否为第一列且非标题行
  if (Col = 0) and (Row > 0) then
  begin
    CellText := StringGrid1.Cells[Col, Row];

    // 处理当前单元格的值
    if CellText.IsEmpty then
      CurrentValue := 0
    else if not TryStrToInt(CellText, CurrentValue) then
      CurrentValue := 0; // 非数字内容视为0

    // 根据按键调整数值
    if Button = mbLeft then
      Inc(CurrentValue)
    else if Button = mbRight then
      Dec(CurrentValue);

    // 更新单元格内容
    if (Button = mbRight) and (CurrentValue <= 0) then
      StringGrid1.Cells[Col, Row] := ''
    else
      StringGrid1.Cells[Col, Row] := IntToStr(CurrentValue);
  end;

end;

procedure TForm1.StringGrid2MouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
var
  Col, Row: Longint;
  CurrentValue: Integer;
  CellText: string;
  i: Integer;
begin
  // 获取点击的单元格位置
  StringGrid2.MouseToCell(X, Y, Col, Row);

  // 检查是否为第一列且非标题行
  if (Col = 0) and (Row > 0) then
  begin
    // 获取当前单元格的值
    CellText := StringGrid2.Cells[Col, Row];

    // 切换选中状态（如果是✓就清空，否则设为✓）
    if CellText = '✓' then
      StringGrid2.Cells[Col, Row] := ''
    else
      StringGrid2.Cells[Col, Row] := '1';

    // 处理当前行及之后的行
    for i := Row to StringGrid2.RowCount - 1 do
    begin
      if i = Row then
        // 当前行已经处理过，跳过
        Continue;
      // 设置后续行为✓
      StringGrid2.Cells[Col, i] := '1';
    end;

    // 处理当前行之前的行
    for i := 1 to Row - 1 do  // 从1开始跳过标题行
    begin
      // 设置之前的行为空
      StringGrid2.Cells[Col, i] := '';
    end;
  end;
end;

