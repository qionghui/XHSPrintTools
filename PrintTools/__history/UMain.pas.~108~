procedure TForm1.SaveExemptConfig;
var
  FilePath: string;
  JSONString: TStringList;
  ConfigJSON: TJSONObject;
  i: Integer;
  SpecID: string;
  ExemptNum: Integer;
  Stream: TMemoryStream;
  Buffer: TBytes;
begin
  // 获取配置文件路径
  FilePath := ExtractFilePath(ParamStr(0)) + 'exempt_config.json';

  // 创建JSON对象
  ConfigJSON := TJSONObject.Create;
  Stream := TMemoryStream.Create;
  try
    // 遍历StringGrid1，收集免打数量
    for i := 1 to StringGrid1.RowCount - 1 do
    begin
      // 获取规格ID（使用找到的规格ID列）
      if FSpecIDColumn > 0 then
        SpecID := StringGrid1.Cells[FSpecIDColumn, i]
      else
        SpecID := '';

      if not SpecID.IsEmpty then
      begin
        // 获取免打数量
        if TryStrToInt(StringGrid1.Cells[1, i], ExemptNum) and (ExemptNum > 0) then
        begin
          // 添加到JSON对象
          ConfigJSON.AddPair(SpecID, TJSONNumber.Create(ExemptNum));
        end;
      end;
    end;

    // 写入UTF-8 BOM
    Stream.WriteBuffer(#$EF#$BB#$BF, 3);

    // 获取UTF-8编码的JSON内容
    JSONString := TStringList.Create;
    try
      JSONString.Text := ConfigJSON.ToJSON;
      Buffer := TEncoding.UTF8.GetBytes(JSONString.Text);
      Stream.WriteBuffer(Buffer[0], Length(Buffer));
    finally
      JSONString.Free;
    end;

    // 保存到文件
    Stream.SaveToFile(FilePath);
  finally
    Stream.Free;
    ConfigJSON.Free;
  end;
end;

procedure TForm1.LoadExemptConfig;
var
  FilePath: string;
  JSONString: TStringList;
  ConfigJSON: TJSONObject;
  i: Integer;
  SpecID: string;
  ExemptNum: Integer;
  Pair: TJSONPair;
  Stream: TMemoryStream;
  Buffer: TBytes;
begin
  // 获取配置文件路径
  FilePath := ExtractFilePath(ParamStr(0)) + 'exempt_config.json';

  // 检查文件是否存在
  if not FileExists(FilePath) then
    Exit;

  try
    Stream := TMemoryStream.Create;
    JSONString := TStringList.Create;
    try
      // 加载文件到流
      Stream.LoadFromFile(FilePath);

      // 检查并跳过BOM
      if Stream.Size >= 3 then
      begin
        SetLength(Buffer, 3);
        Stream.ReadBuffer(Buffer[0], 3);
        // 检查是否是UTF-8 BOM (EF BB BF)
        if (Buffer[0] = $EF) and (Buffer[1] = $BB) and (Buffer[2] = $BF) then
        begin
          // BOM已跳过，继续读取剩余内容
        end
        else
        begin
          // 不是BOM，将指针重置到开始位置
          Stream.Position := 0;
        end;
      end;

      // 读取UTF-8内容
      SetLength(Buffer, Stream.Size - Stream.Position);
      if Length(Buffer) > 0 then
        Stream.ReadBuffer(Buffer[0], Length(Buffer));

      JSONString.Text := TEncoding.UTF8.GetString(Buffer);
      ConfigJSON := TJSONObject.ParseJSONValue(JSONString.Text) as TJSONObject;
      if Assigned(ConfigJSON) then
      begin
        try
          // 遍历StringGrid1，设置免打数量
        for i := 1 to StringGrid1.RowCount - 1 do
        begin
          // 获取规格ID（使用找到的规格ID列）
          if FSpecIDColumn > 0 then
            SpecID := StringGrid1.Cells[FSpecIDColumn, i]
          else
            SpecID := '';

          if not SpecID.IsEmpty then
          begin
            // 查找对应的免打数量
            Pair := ConfigJSON.Get(SpecID);
            if Assigned(Pair) and (Pair.JsonValue is TJSONNumber) then
            begin
              ExemptNum := (Pair.JsonValue as TJSONNumber).AsInt;
              if ExemptNum > 0 then
                StringGrid1.Cells[1, i] := IntToStr(ExemptNum)
              else
                StringGrid1.Cells[1, i] := '';
            end;
          end;
        end;
        finally
          ConfigJSON.Free;
        end;
      end;
    finally
      Stream.Free;
      JSONString.Free;
    end;
  except
    on E: Exception do
      ShowMessage('读取免打配置文件时发生错误：' + E.Message);
  end;
end;

procedure TForm1.SaveGridToExcel(const FileName: string; StringGrid: TStringGrid);
var
  ExcelApp, Workbook, Sheet: Variant;
  i, j, ExcelRow: Integer;
begin
  // 初始化Excel应用程序
  ExcelApp := CreateOleObject('Excel.Application');
  try
    ExcelApp.Visible := False;
    ExcelApp.DisplayAlerts := False;

    // 创建新工作簿
    Workbook := ExcelApp.Workbooks.Add;
    try
      // 获取第一个工作表
      Sheet := Workbook.Sheets[1];

      // 写入列名（第一行）
      for j := 0 to StringGrid.ColCount - 1 do
      begin
        Sheet.Cells[1, j + 1] := StringGrid.Cells[j, 0];
      end;

      // 初始化Excel行号（从第二行开始）
      ExcelRow := 2;

      // 将StringGrid的内容写入Excel
      for i := 1 to StringGrid.RowCount - 1 do
      begin
        // 筛选“数量”列大于0的行
        if StrToIntDef(StringGrid.Cells[0, i], 0) > 0 then
        begin
          // 写入当前行数据
          for j := 0 to StringGrid.ColCount - 1 do
          begin
            Sheet.Cells[ExcelRow, j + 1] := StringGrid.Cells[j, i];
          end;
          // 增加Excel行号
          Inc(ExcelRow);
        end;
      end;

      // 保存工作簿
      if ExcelRow > 2 then
        Workbook.SaveAs(FileName);
    finally
      // 关闭工作簿
      Workbook.Close(False);
    end;
  finally
    // 退出Excel应用程序
    ExcelApp.Quit;
    ExcelApp := Unassigned;
  end;
end;

procedure TForm1.StringGrid1MouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
var
  Col, Row: Longint;
  CurrentValue: Integer;
  CellText: string;
begin
  // 获取点击的单元格位置
  StringGrid1.MouseToCell(X, Y, Col, Row);

  // 检查是否为第一列或第二列且非标题行
  if ((Col = 0) or (Col = 1)) and (Row > 0) then
  begin
    CellText := StringGrid1.Cells[Col, Row];

    // 处理当前单元格的值
    if CellText.IsEmpty then
      CurrentValue := 0
    else if not TryStrToInt(CellText, CurrentValue) then
      CurrentValue := 0; // 非数字内容视为0

    // 根据按键调整数值
    if Button = mbLeft then
      Inc(CurrentValue)
    else if Button = mbRight then
      Dec(CurrentValue);

    // 更新单元格内容
    if (Button = mbRight) and (CurrentValue <= 0) then
      StringGrid1.Cells[Col, Row] := ''
    else
      StringGrid1.Cells[Col, Row] := IntToStr(CurrentValue);

    // 如果是免打列，保存配置
    if Col = 1 then
    begin
      SaveExemptConfig;
    end;
  end;

end;

procedure TForm1.StringGrid2MouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
var
  Col, Row: Longint;
  CurrentValue: Integer;
  CellText: string;
  i: Integer;
begin
  // 获取点击的单元格位置
  StringGrid2.MouseToCell(X, Y, Col, Row);

  // 检查是否为第一列且非标题行
  if (Col = 0) and (Row > 0) then
  begin
    // 获取当前单元格的值
    CellText := StringGrid2.Cells[Col, Row];

    // 切换选中状态（如果是✓就清空，否则设为✓）
    if CellText = '✓' then
      StringGrid2.Cells[Col, Row] := ''
    else
      StringGrid2.Cells[Col, Row] := '1';

    // 处理当前行及之后的行
    for i := Row to StringGrid2.RowCount - 1 do
    begin
      if i = Row then
        // 当前行已经处理过，跳过
        Continue;
      // 设置后续行为✓
      StringGrid2.Cells[Col, i] := '1';
    end;

    // 处理当前行之前的行
    for i := 1 to Row - 1 do  // 从1开始跳过标题行
    begin
      // 设置之前的行为空
      StringGrid2.Cells[Col, i] := '';
    end;
  end;
end;

procedure TForm1.Timer1Timer(Sender: TObject);
var
  FilePath: string;
  JSONString: TStringList;
  ConfigJSON: TJSONObject;
begin
  // 先禁用定时器，避免重入
  Timer1.Enabled := False;

  try
    // 获取当前可执行文件所在的文件夹路径
    FilePath := ExtractFilePath(ParamStr(0)) + 'latest_print_file.xlsx';

    // 检查文件是否存在
    if FileExists(FilePath) then
      LoadExcelToGrid(FilePath, StringGrid2)
    else
      ShowMessage('文件 latest_print_file.xlsx 未找到！');

    StringGrid2.Options := StringGrid2.Options + [goEditing];
    StringGrid2.FixedCols := 0;
    FRowHeights := StringGrid2.DefaultRowHeight;
  finally
    // 确保定时器重新开启，以便下次自动加载
    Timer1.Enabled := True;
  end;
end;

procedure TForm1.Timer2Timer(Sender: TObject);
begin
  // 先禁用定时器，避免重入
  Timer2.Enabled := False;

  try
    // 刷新免打配置
    LoadExemptConfig;
  finally
    // 确保定时器重新开启，以便下次自动加载
    Timer2.Enabled := True;
  end;
end;

