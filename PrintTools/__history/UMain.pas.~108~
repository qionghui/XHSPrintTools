procedure TForm1.AutoSizeColumns(Grid: TStringGrid);
var
  i, j, MaxWidth, CellWidth: Integer;
begin
  for i := 0 to Grid.ColCount - 1 do
  begin
    MaxWidth := 0;

    // 遍历每一行，计算最大宽度
    for j := 0 to Grid.RowCount - 1 do
    begin
      CellWidth := Grid.Canvas.TextWidth(Grid.Cells[i, j]) + 10; // 增加一些边距
      if CellWidth > MaxWidth then
        MaxWidth := CellWidth;
    end;

    // 设置列宽
    Grid.ColWidths[i] := MaxWidth;
  end;
end;

